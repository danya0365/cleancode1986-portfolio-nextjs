{
  "name": "@cleancode1986/ai-chat-bubble",
  "version": "1.0.0",
  "description": "A plug-and-play AI Chat Widget with full state management and Next.js App Router API handlers.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./dist/*": "./dist/*",
    "./server.js": "./server.js",
    "./server.d.ts": "./server.d.ts",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "server.js",
    "server.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "lucide-react": "^0.300.0 || ^0.400.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^15.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@line/bot-sdk": "^9.7.0",
    "dotenv": "^16.4.7"
  }
}
